# Copie este arquivo para .env.local e preencha os valores reais
# .env.local NÃO deve ser commitado (está no .gitignore)

# URL do backend REST (ex: http://localhost:3000 em dev, https://api.greetup.app em prod)
NEXT_PUBLIC_API_URL=

# URL do gateway WebSocket (ex: http://localhost:3001 em dev)
NEXT_PUBLIC_GATEWAY_URL=
