generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())
  customers Customer[]
  events    Event[]
  orders    Order[]
  products  Product[]
  tables    Table[]
  sessions  TableSession[]
  users     User[]
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String
  passwordHash     String
  role             Role              @default(ADMIN)
  active           Boolean           @default(true)
  lastLogin        DateTime?
  createdAt        DateTime          @default(now())
  companyId        String
  operatorFunction OperatorFunction?
  sessions         TableSession[]    @relation("SessionAttendant")
  company          Company           @relation(fields: [companyId], references: [id])

  @@unique([email, companyId])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ProductCategory
  price       Decimal?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  companyId   String
  orderItems  OrderItem[]
  company     Company         @relation(fields: [companyId], references: [id])
}

model Table {
  id        String         @id @default(cuid())
  code      String
  status    TableStatus    @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  companyId String
  company   Company        @relation(fields: [companyId], references: [id])
  sessions  TableSession[]

  @@unique([code, companyId])
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  employer  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  companyId String
  company   Company        @relation(fields: [companyId], references: [id])
  sessions  TableSession[]
}

model TableSession {
  id          String    @id @default(cuid())
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  companyId   String
  tableId     String
  customerId  String?
  attendantId String
  eventId     String?
  orders      Order[]
  attendant   User      @relation("SessionAttendant", fields: [attendantId], references: [id])
  company     Company   @relation(fields: [companyId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])
  event       Event?    @relation(fields: [eventId], references: [id])
  table       Table     @relation(fields: [tableId], references: [id])
}

model Event {
  id        String         @id @default(cuid())
  name      String
  date      DateTime       @default(now())
  status    EventStatus    @default(DRAFT)
  companyId String
  company   Company        @relation(fields: [companyId], references: [id])
  sessions  TableSession[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([companyId, status])
}

model Order {
  id        String       @id @default(cuid())
  status    OrderStatus  @default(OPEN)
  toGo      Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  companyId String
  sessionId String
  company   Company      @relation(fields: [companyId], references: [id])
  session   TableSession @relation(fields: [sessionId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  id         String     @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int        @default(1)
  notes      String?
  withCheese Boolean?
  courtesy   Boolean    @default(false)
  status     ItemStatus @default(PENDENTE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  order      Order      @relation(fields: [orderId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])
}

enum Role {
  ADMIN
  GERENTE
  OPERADOR
}

enum OperatorFunction {
  COZINHA
  GARCOM
  DISPLAY
}

enum ProductCategory {
  COMIDA
  BEBIDA
  MASSA
}

enum TableStatus {
  OPEN
  OCCUPIED
  CLOSED
}

enum OrderStatus {
  OPEN
  CLOSED
}

enum ItemStatus {
  PENDENTE
  EM_PREPARO
  PRONTO
  ENTREGUE
}

enum EventStatus {
  DRAFT
  ACTIVE
  CLOSED
}
