{
  "info": {
    "name": "Greetup API — Sprint 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (cria empresa + ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Admin\",\n  \"email\": \"admin@empresa.com\",\n  \"password\": \"senha123\",\n  \"companyName\": \"Empresa X\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@empresa.com\",\n  \"password\": \"senha123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Criar usuário",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maria Gerente\",\n  \"email\": \"gerente@empresa.com\",\n  \"password\": \"senha123\",\n  \"role\": \"GERENTE\"\n}"
            }
          }
        },
        {
          "name": "Listar usuários",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "Buscar usuário por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users/:id"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Criar produto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Coca-Cola\",\n  \"description\": \"Lata 350ml\",\n  \"category\": \"BEBIDA\"\n}"
            }
          }
        },
        {
          "name": "Listar produtos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Buscar produto por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/products/:id"
          }
        },
        {
          "name": "Atualizar produto",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/products/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Coca-Cola Zero\",\n  \"active\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tables",
      "item": [
        {
          "name": "Criar mesa",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tables",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"MESA-01\"\n}"
            }
          }
        },
        {
          "name": "Listar mesas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tables"
          }
        },
        {
          "name": "Buscar mesa por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tables/:id"
          }
        },
        {
          "name": "Atualizar status da mesa",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tables/:id/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"OCCUPIED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Criar visitante",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carlos Visitante\",\n  \"email\": \"carlos@parceira.com\",\n  \"phone\": \"31999990000\",\n  \"employer\": \"Empresa Parceira\"\n}"
            }
          }
        },
        {
          "name": "Listar visitantes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/customers"
          }
        },
        {
          "name": "Buscar visitante por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/customers/:id"
          }
        },
        {
          "name": "Atualizar visitante",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/customers/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"31988880000\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Criar pedido (publica order:created)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tableId\": \"<id_da_mesa>\",\n  \"customerId\": \"<id_do_visitante>\",\n  \"items\": [\n    {\n      \"productId\": \"<id_do_produto>\",\n      \"quantity\": 2,\n      \"notes\": \"sem gelo\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Listar pedidos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Buscar pedido por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/:id"
          }
        },
        {
          "name": "Fechar pedido (publica order:closed)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/:id/close"
          }
        },
        {
          "name": "Atualizar status de item (publica order.item:status_changed)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/:orderId/items/:itemId/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARO\"\n}"
            }
          }
        }
      ]
    }
  ]
}
