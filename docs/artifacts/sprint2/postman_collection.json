{
  "info": {
    "name": "Greetup API — Sprint 2+",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "tableId", "value": "" },
    { "key": "sessionId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "attendantId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (cria empresa + ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('companyId', json.companyId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Admin\",\n  \"email\": \"admin@empresa.com\",\n  \"password\": \"senha123\",\n  \"companyName\": \"Empresa X\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "pm.collectionVariables.set('companyId', json.user.companyId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@empresa.com\",\n  \"password\": \"senha123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Criar GERENTE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('attendantId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maria Gerente\",\n  \"email\": \"gerente@empresa.com\",\n  \"password\": \"senha123\",\n  \"role\": \"GERENTE\"\n}"
            }
          }
        },
        {
          "name": "Criar OPERADOR",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pedro Operador\",\n  \"email\": \"operador@empresa.com\",\n  \"password\": \"senha123\",\n  \"role\": \"OPERADOR\"\n}"
            }
          }
        },
        {
          "name": "Listar usuários",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Criar produto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('productId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Coca-Cola\",\n  \"description\": \"Lata 350ml\",\n  \"category\": \"BEBIDA\"\n}"
            }
          }
        },
        {
          "name": "Listar produtos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/products"
          }
        }
      ]
    },
    {
      "name": "Tables",
      "item": [
        {
          "name": "Criar mesa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('tableId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tables",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"MESA-01\"\n}"
            }
          }
        },
        {
          "name": "Listar mesas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tables"
          }
        },
        {
          "name": "Buscar mesa por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tables/{{tableId}}"
          }
        },
        {
          "name": "Atualizar status da mesa (manual)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tables/{{tableId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CLOSED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Abrir sessão na mesa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('sessionId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tables/{{tableId}}/sessions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attendantId\": \"{{attendantId}}\",\n  \"customerId\": \"{{customerId}}\"\n}"
            }
          }
        },
        {
          "name": "Buscar sessão ativa da mesa",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tables/{{tableId}}/sessions/active"
          }
        },
        {
          "name": "Listar sessões da mesa",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/tables/{{tableId}}/sessions?onlyActive=false",
              "query": [{ "key": "onlyActive", "value": "false" }]
            }
          }
        },
        {
          "name": "Buscar sessão por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tables/{{tableId}}/sessions/{{sessionId}}"
          }
        },
        {
          "name": "Fechar sessão",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tables/{{tableId}}/sessions/{{sessionId}}/close"
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Criar visitante",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('customerId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carlos Visitante\",\n  \"email\": \"carlos@parceira.com\",\n  \"phone\": \"31999990000\",\n  \"employer\": \"Empresa Parceira\"\n}"
            }
          }
        },
        {
          "name": "Listar visitantes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/customers"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Criar pedido (publica order.created)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('orderId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 2,\n      \"notes\": \"sem gelo\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Listar pedidos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Listar pedidos da sessão",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/orders?sessionId={{sessionId}}",
              "query": [{ "key": "sessionId", "value": "{{sessionId}}" }]
            }
          }
        },
        {
          "name": "Buscar pedido por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Fechar pedido (publica order.closed)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/{{orderId}}/close"
          }
        },
        {
          "name": "Atualizar status de item (publica order.item.status_changed)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/{{orderId}}/items/:itemId/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARO\"\n}"
            }
          }
        }
      ]
    }
  ]
}
